{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Malaysia's nesting beaches and coastal temperatures",
    "subtitle": "Circle size = annual nests; colour = mean sea surface temperature (°C). Sources: Dept. of Fisheries Malaysia, NOAA ERSST",
    "fontSize": 16,
    "subtitleFontSize": 11,
    "anchor": "start",
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 420,
  "background": "#f7f9fb",
  "config": {"view": {"stroke": null}},
  "projection": {"type": "mercator", "center": [109, 4], "scale": 1800},
  "layer": [
    {
      "data": {"values": [{"type": "ocean"}]},
      "mark": {"type": "rect", "color": "#d4e8f0"},
      "encoding": {
        "x": {"value": 0}, "y": {"value": 0},
        "x2": {"value": 900}, "y2": {"value": 450}
      }
    },
    {
      "data": {
        "url": "https://raw.githubusercontent.com/vega/vega-datasets/master/data/world-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {"type": "geoshape", "fill": "#e0ddd5", "stroke": "#bbb", "strokeWidth": 0.5}
    },
    {
      "data": {
        "values": [
          {"beach": "Turtle Islands Park (Selingan)", "state": "Sabah", "lat": 6.17, "lon": 118.07, "nests": 12500, "sst": 29.4, "species": "Green"},
          {"beach": "Libaran Island", "state": "Sabah", "lat": 6.06, "lon": 118.12, "nests": 1800, "sst": 29.5, "species": "Green"},
          {"beach": "Gulisan Island", "state": "Sabah", "lat": 6.19, "lon": 118.04, "nests": 950, "sst": 29.4, "species": "Green"},
          {"beach": "Chagar Hutang", "state": "Terengganu", "lat": 5.79, "lon": 103.01, "nests": 970, "sst": 29.8, "species": "Green"},
          {"beach": "Rantau Abang", "state": "Terengganu", "lat": 4.82, "lon": 103.41, "nests": 2, "sst": 30.1, "species": "Leatherback"},
          {"beach": "Pulau Perhentian", "state": "Terengganu", "lat": 5.92, "lon": 102.73, "nests": 320, "sst": 29.7, "species": "Hawksbill"},
          {"beach": "Ma' Daerah", "state": "Terengganu", "lat": 4.70, "lon": 103.44, "nests": 680, "sst": 30.0, "species": "Green"},
          {"beach": "Melaka coast", "state": "Melaka", "lat": 2.27, "lon": 102.26, "nests": 450, "sst": 30.3, "species": "Hawksbill"},
          {"beach": "Segari", "state": "Perak", "lat": 4.30, "lon": 100.57, "nests": 110, "sst": 29.9, "species": "Olive Ridley"},
          {"beach": "Tioman Island", "state": "Pahang", "lat": 2.79, "lon": 104.17, "nests": 180, "sst": 29.6, "species": "Hawksbill"},
          {"beach": "Pulau Tinggi", "state": "Johor", "lat": 2.30, "lon": 104.12, "nests": 75, "sst": 29.8, "species": "Hawksbill"},
          {"beach": "Penang coast", "state": "Penang", "lat": 5.42, "lon": 100.31, "nests": 40, "sst": 30.2, "species": "Olive Ridley"}
        ]
      },
      "mark": {"type": "circle", "opacity": 0.85, "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "size": {
          "field": "nests",
          "type": "quantitative",
          "scale": {"type": "sqrt", "range": [20, 2200]},
          "legend": {"title": "Annual nests", "orient": "bottom-left"}
        },
        "color": {
          "field": "sst",
          "type": "quantitative",
          "scale": {"scheme": "blueorange", "domain": [28.5, 31.0]},
          "legend": {"title": "Mean SST (°C)", "orient": "bottom-left"}
        },
        "tooltip": [
          {"field": "beach", "title": "Beach"},
          {"field": "state", "title": "State"},
          {"field": "species", "title": "Dominant species"},
          {"field": "nests", "title": "Annual nests", "format": ","},
          {"field": "sst", "title": "Mean SST (°C)", "format": ".1f"}
        ]
      }
    }
  ]
}
