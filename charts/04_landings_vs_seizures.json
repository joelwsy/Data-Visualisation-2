{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Conservation paradox: more nests attract more poachers",
    "subtitle": "Total nests on protected beaches vs estimated eggs lost to poaching. Sources: Dept. of Fisheries, TRAFFIC",
    "fontSize": 16,
    "subtitleFontSize": 11,
    "anchor": "start",
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 340,
  "background": "#f7f9fb",
  "config": {"view": {"stroke": null}, "axis": {"grid": true, "gridOpacity": 0.15}},
  "data": {
    "values": [
      {"year": 2010, "nests": 8200, "eggs_poached": 4100},
      {"year": 2011, "nests": 8900, "eggs_poached": 4600},
      {"year": 2012, "nests": 9400, "eggs_poached": 5400},
      {"year": 2013, "nests": 10100, "eggs_poached": 6200},
      {"year": 2014, "nests": 10800, "eggs_poached": 7100},
      {"year": 2015, "nests": 11500, "eggs_poached": 8400},
      {"year": 2016, "nests": 12200, "eggs_poached": 9200},
      {"year": 2017, "nests": 12800, "eggs_poached": 7800},
      {"year": 2018, "nests": 13100, "eggs_poached": 7400},
      {"year": 2019, "nests": 13500, "eggs_poached": 8600},
      {"year": 2020, "nests": 13800, "eggs_poached": 4900},
      {"year": 2021, "nests": 14200, "eggs_poached": 5700},
      {"year": 2022, "nests": 14500, "eggs_poached": 7600},
      {"year": 2023, "nests": 14800, "eggs_poached": 8400}
    ]
  },
  "transform": [
    {"calculate": "datum.nests * 100", "as": "total_eggs"},
    {"fold": ["total_eggs", "eggs_poached"], "as": ["metric", "value"]},
    {"calculate": "datum.metric == 'total_eggs' ? 'Eggs laid (estimated)' : 'Eggs lost to poaching'", "as": "series"}
  ],
  "mark": {"type": "line", "strokeWidth": 2.8, "point": {"size": 55, "filled": true}},
  "encoding": {
    "x": {"field": "year", "type": "ordinal", "axis": {"title": "Year", "labelAngle": -45}},
    "y": {"field": "value", "type": "quantitative", "axis": {"title": "Number of eggs"}},
    "color": {
      "field": "series",
      "type": "nominal",
      "scale": {
        "domain": ["Eggs laid (estimated)", "Eggs lost to poaching"],
        "range": ["#2a9d8f", "#e76f51"]
      },
      "legend": {"title": null, "orient": "top"}
    },
    "strokeDash": {
      "field": "series",
      "type": "nominal",
      "scale": {"domain": ["Eggs laid (estimated)", "Eggs lost to poaching"], "range": [[0], [6, 3]]},
      "legend": null
    },
    "tooltip": [
      {"field": "year", "title": "Year"},
      {"field": "series", "title": "Metric"},
      {"field": "value", "title": "Eggs", "format": ","}
    ]
  }
}
