{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Protected beaches hatch — unprotected beaches lose eggs",
    "subtitle": "Distance from 50% line shows how each beach compares to a break-even outcome",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "anchor": "start",
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 320,
  "background": "#f7f9fb",
  "config": {"view": {"stroke": null}, "axis": {"grid": false}},
  "data": {
    "values": [
      {"beach": "Chagar Hutang (Terengganu)", "protection": "Fully protected (SEATRU)", "hatch_pct": 87, "deviation": 37},
      {"beach": "Selingan Island (Sabah)", "protection": "Marine Park", "hatch_pct": 82, "deviation": 32},
      {"beach": "Libaran (Sabah)", "protection": "Community-led", "hatch_pct": 74, "deviation": 24},
      {"beach": "Pulau Tinggi (Johor)", "protection": "Marine Park", "hatch_pct": 71, "deviation": 21},
      {"beach": "Tioman (Pahang)", "protection": "Marine Park", "hatch_pct": 68, "deviation": 18},
      {"beach": "Segari (Perak, hatchery)", "protection": "Hatchery-managed", "hatch_pct": 62, "deviation": 12},
      {"beach": "Melaka coast (managed)", "protection": "Hatchery-managed", "hatch_pct": 58, "deviation": 8},
      {"beach": "Melaka coast (in-situ)", "protection": "Partial", "hatch_pct": 42, "deviation": -8},
      {"beach": "Perhentian (unmanaged sections)", "protection": "Partial", "hatch_pct": 38, "deviation": -12},
      {"beach": "Perak coast (in-situ)", "protection": "Partial", "hatch_pct": 32, "deviation": -18},
      {"beach": "Rural Terengganu (unmanaged)", "protection": "None", "hatch_pct": 18, "deviation": -32},
      {"beach": "Rural Pahang (unmanaged)", "protection": "None", "hatch_pct": 12, "deviation": -38}
    ]
  },
  "layer": [
    {
      "mark": {"type": "bar", "stroke": "white", "strokeWidth": 1, "cornerRadiusEnd": 3},
      "encoding": {
        "y": {
          "field": "beach",
          "type": "nominal",
          "sort": {"field": "deviation", "order": "descending"},
          "axis": {"title": null, "labelFontSize": 10}
        },
        "x": {
          "field": "deviation",
          "type": "quantitative",
          "axis": {"title": "Hatching rate vs. 50% break-even (percentage points)", "titleFontSize": 11}
        },
        "color": {
          "field": "protection",
          "type": "nominal",
          "scale": {
            "domain": ["Fully protected (SEATRU)", "Marine Park", "Community-led", "Hatchery-managed", "Partial", "None"],
            "range": ["#1b5e20", "#2a9d8f", "#80b918", "#e9c46a", "#f4a261", "#e76f51"]
          },
          "legend": {"title": "Protection level", "orient": "bottom", "columns": 3}
        },
        "tooltip": [
          {"field": "beach", "title": "Beach"},
          {"field": "protection", "title": "Protection"},
          {"field": "hatch_pct", "title": "Hatch rate (%)"},
          {"field": "deviation", "title": "Deviation from 50%"}
        ]
      }
    },
    {
      "mark": {"type": "rule", "color": "#333", "strokeWidth": 1.5},
      "encoding": {
        "x": {"datum": 0}
      }
    },
    {
      "data": {"values": [{"x": 0, "y": "Chagar Hutang (Terengganu)", "label": "50% break-even line"}]},
      "mark": {"type": "text", "fontSize": 10, "fontStyle": "italic", "color": "#333", "dy": -10, "align": "center"},
      "encoding": {
        "x": {"field": "x", "type": "quantitative"},
        "y": {"field": "y", "type": "nominal"},
        "text": {"field": "label"}
      }
    }
  ]
}
