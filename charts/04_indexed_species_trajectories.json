{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Three species, three trajectories since 1980",
    "subtitle": "Each species rebased to 100 in 1980 — values show % of 1980 nests",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "anchor": "start",
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 340,
  "background": "#f7f9fb",
  "config": {"view": {"stroke": null}, "axis": {"grid": false}},
  "data": {
    "values": [
      {"year": 1980, "species": "Leatherback", "nests": 2500},
      {"year": 1985, "species": "Leatherback", "nests": 600},
      {"year": 1990, "species": "Leatherback", "nests": 320},
      {"year": 1995, "species": "Leatherback", "nests": 90},
      {"year": 2000, "species": "Leatherback", "nests": 13},
      {"year": 2005, "species": "Leatherback", "nests": 4},
      {"year": 2010, "species": "Leatherback", "nests": 1},
      {"year": 2015, "species": "Leatherback", "nests": 0},
      {"year": 2020, "species": "Leatherback", "nests": 1},
      {"year": 2023, "species": "Leatherback", "nests": 0},
      {"year": 1980, "species": "Green", "nests": 9800},
      {"year": 1985, "species": "Green", "nests": 8400},
      {"year": 1990, "species": "Green", "nests": 7600},
      {"year": 1995, "species": "Green", "nests": 6900},
      {"year": 2000, "species": "Green", "nests": 6200},
      {"year": 2005, "species": "Green", "nests": 5800},
      {"year": 2010, "species": "Green", "nests": 5400},
      {"year": 2015, "species": "Green", "nests": 5100},
      {"year": 2020, "species": "Green", "nests": 5300},
      {"year": 2023, "species": "Green", "nests": 5470},
      {"year": 1980, "species": "Hawksbill", "nests": 1850},
      {"year": 1985, "species": "Hawksbill", "nests": 1620},
      {"year": 1990, "species": "Hawksbill", "nests": 1380},
      {"year": 1995, "species": "Hawksbill", "nests": 1100},
      {"year": 2000, "species": "Hawksbill", "nests": 920},
      {"year": 2005, "species": "Hawksbill", "nests": 810},
      {"year": 2010, "species": "Hawksbill", "nests": 760},
      {"year": 2015, "species": "Hawksbill", "nests": 820},
      {"year": 2020, "species": "Hawksbill", "nests": 850},
      {"year": 2023, "species": "Hawksbill", "nests": 875},
      {"year": 1980, "species": "Olive Ridley", "nests": 320},
      {"year": 1985, "species": "Olive Ridley", "nests": 240},
      {"year": 1990, "species": "Olive Ridley", "nests": 180},
      {"year": 1995, "species": "Olive Ridley", "nests": 120},
      {"year": 2000, "species": "Olive Ridley", "nests": 90},
      {"year": 2005, "species": "Olive Ridley", "nests": 75},
      {"year": 2010, "species": "Olive Ridley", "nests": 68},
      {"year": 2015, "species": "Olive Ridley", "nests": 70},
      {"year": 2020, "species": "Olive Ridley", "nests": 65},
      {"year": 2023, "species": "Olive Ridley", "nests": 66}
    ]
  },
  "transform": [
    {
      "calculate": "datum.species == 'Green' ? 9800 : datum.species == 'Hawksbill' ? 1850 : datum.species == 'Olive Ridley' ? 320 : 2500",
      "as": "base_1980"
    },
    {
      "calculate": "datum.nests / datum.base_1980 * 100",
      "as": "index"
    }
  ],
  "layer": [
    {
      "mark": {"type": "rule", "color": "#999", "strokeDash": [3, 3]},
      "encoding": {
        "y": {"datum": 100}
      }
    },
    {
      "params": [
        {
          "name": "species_select",
          "select": {"type": "point", "fields": ["species"]},
          "bind": "legend"
        }
      ],
      "mark": {"type": "line", "strokeWidth": 2.8, "point": {"size": 50, "filled": true}},
      "encoding": {
        "x": {"field": "year", "type": "quantitative", "axis": {"title": "Year", "format": "d"}},
        "y": {"field": "index", "type": "quantitative", "axis": {"title": "Nests (1980 = 100)"}},
        "color": {
          "field": "species",
          "type": "nominal",
          "scale": {
            "domain": ["Green", "Hawksbill", "Olive Ridley", "Leatherback"],
            "range": ["#2a9d8f", "#e9c46a", "#f4a261", "#264653"]
          },
          "legend": {"title": "Species (click to filter)", "orient": "top-right"}
        },
        "opacity": {
          "condition": {"param": "species_select", "value": 1},
          "value": 0.15
        },
        "tooltip": [
          {"field": "year", "title": "Year"},
          {"field": "species", "title": "Species"},
          {"field": "nests", "title": "Nests", "format": ","},
          {"field": "index", "title": "Index (1980=100)", "format": ".1f"}
        ]
      }
    }
  ]
}
