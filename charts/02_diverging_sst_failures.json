  },
  "transform": [
    {
      "calculate": "datum.anomaly >= 0 ? 'Warmer' : 'Cooler'",
      "as": "direction"
    }
  ],
  "vconcat": [
    {
      "width": "container",
      "height": 200,
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 2
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "title": null,
            "labelAngle": -45,
            "labelFontSize": 9
          }
        },
        "y": {
          "field": "anomaly",
          "type": "quantitative",
          "axis": {
            "title": "Temperature anomaly (\u00b0C)"
          }
        },
        "color": {
          "field": "direction",
          "type": "nominal",
          "scale": {
            "domain": [
              "Warmer",
              "Cooler"
            ],
            "range": [
              "#e76f51",
              "#0077b6"
            ]
          },
          "legend": null
        },
        "tooltip": [
          {
            "field": "year",
            "title": "Year"
          },
          {
            "field": "anomaly",
            "title": "SST anomaly (\u00b0C)",
            "format": "+.2f"
          },
          {
            "field": "failures",
            "title": "Nest failures"
          }
        ]
      }
    },
    {
      "width": "container",
      "height": 140,
      "mark": {
        "type": "line",
        "color": "#264653",
        "strokeWidth": 2.5,
        "point": {
          "size": 45,
          "filled": true,
          "color": "#264653"
        }
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "ordinal",
          "axis": {
            "title": "Year",
            "labelAngle": -45,
            "labelFontSize": 9
          }
        },
        "y": {
          "field": "failures",
          "type": "quantitative",
          "axis": {
            "title": "Total nest failures"
          }
        },
        "tooltip": [
          {
            "field": "year",
            "title": "Year"
          },
          {
            "field": "failures",
            "title": "Nest failures"
          },
          {
            "field": "anomaly",
            "title": "SST anomaly (\u00b0C)",
            "format": "+.2f"
          }
        ]
      }
    }
  ]
