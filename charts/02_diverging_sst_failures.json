    "fontSize": 16,
    "subtitleFontSize": 11,
    "anchor": "start",
    "subtitleColor": "#555"
  },
  "background": "#f7f9fb",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": false
    }
  },
  "data": {
