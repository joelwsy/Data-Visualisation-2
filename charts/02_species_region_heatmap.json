{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Each species has its own coastline",
    "subtitle": "Share of national nesting effort by region (row totals = 100%)",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "anchor": "start",
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 220,
  "background": "#f7f9fb",
  "config": {"view": {"stroke": null}, "axis": {"domain": false, "ticks": false}},
  "data": {
    "values": [
      {"species": "Green", "region": "Sabah", "nests": 4130},
      {"species": "Green", "region": "Terengganu", "nests": 1140},
      {"species": "Green", "region": "Pahang", "nests": 95},
      {"species": "Green", "region": "Perak", "nests": 110},
      {"species": "Green", "region": "Johor", "nests": 60},
      {"species": "Green", "region": "Melaka", "nests": 35},
      {"species": "Hawksbill", "region": "Sabah", "nests": 120},
      {"species": "Hawksbill", "region": "Terengganu", "nests": 290},
      {"species": "Hawksbill", "region": "Pahang", "nests": 200},
      {"species": "Hawksbill", "region": "Perak", "nests": 30},
      {"species": "Hawksbill", "region": "Johor", "nests": 95},
      {"species": "Hawksbill", "region": "Melaka", "nests": 140},
      {"species": "Leatherback", "region": "Sabah", "nests": 0},
      {"species": "Leatherback", "region": "Terengganu", "nests": 1},
      {"species": "Leatherback", "region": "Pahang", "nests": 0},
      {"species": "Leatherback", "region": "Perak", "nests": 0},
      {"species": "Leatherback", "region": "Johor", "nests": 0},
      {"species": "Leatherback", "region": "Melaka", "nests": 0},
      {"species": "Olive Ridley", "region": "Sabah", "nests": 15},
      {"species": "Olive Ridley", "region": "Terengganu", "nests": 25},
      {"species": "Olive Ridley", "region": "Pahang", "nests": 8},
      {"species": "Olive Ridley", "region": "Perak", "nests": 12},
      {"species": "Olive Ridley", "region": "Johor", "nests": 4},
      {"species": "Olive Ridley", "region": "Melaka", "nests": 2}
    ]
  },
  "transform": [
    {"joinaggregate": [{"op": "sum", "field": "nests", "as": "species_total"}], "groupby": ["species"]},
    {"calculate": "datum.species_total > 0 ? datum.nests / datum.species_total * 100 : 0", "as": "share"}
  ],
  "mark": {"type": "rect", "stroke": "white", "strokeWidth": 2},
  "encoding": {
    "x": {
      "field": "region",
      "type": "nominal",
      "sort": ["Sabah", "Terengganu", "Pahang", "Perak", "Johor", "Melaka"],
      "axis": {"title": null, "labelAngle": 0, "labelFontSize": 11}
    },
    "y": {
      "field": "species",
      "type": "nominal",
      "sort": ["Green", "Hawksbill", "Olive Ridley", "Leatherback"],
      "axis": {"title": null, "labelFontSize": 11}
    },
    "color": {
      "field": "share",
      "type": "quantitative",
      "scale": {"scheme": "teals", "domain": [0, 100]},
      "legend": {"title": "% of species' nests", "orient": "right", "gradientLength": 150}
    },
    "tooltip": [
      {"field": "species", "title": "Species"},
      {"field": "region", "title": "Region"},
      {"field": "nests", "title": "Nests", "format": ","},
      {"field": "share", "title": "% of species total", "format": ".1f"}
    ]
  }
}
