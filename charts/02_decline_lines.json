  "transform": [
    {
      "fold": [
        "clutches",
        "females"
      ],
      "as": [
        "metric",
        "value"
      ]
    },
    {
      "calculate": "datum.metric == 'clutches' ? 'Total clutches' : 'Estimated nesting females'",
      "as": "metric_label"
    }
  ],
