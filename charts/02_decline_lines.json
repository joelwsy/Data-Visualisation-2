    {
      "mark": {
        "type": "line",
        "point": {
          "size": 40,
          "filled": true
        }
      },
      "encoding": {
        "x": {
          "field": "year",
          "type": "quantitative",
          "axis": {
            "title": "Year",
            "format": "d",
            "tickCount": 8
          },
          "scale": {
            "domain": [
              1958,
              2025
            ]
          }
        },
        "y": {
          "field": "value",
          "type": "quantitative",
          "axis": {
            "title": "Count"
          },
          "scale": {
            "type": "log",
            "domain": [
              1,
              25000
            ]
          }
        },
        "color": {
          "field": "species",
