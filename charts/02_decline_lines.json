            "title": "Species",
            "orient": "right",
            "titleFontSize": 12,
            "labelFontSize": 11
          }
        },
        "strokeDash": {
          "field": "metric_label",
          "type": "nominal",
          "scale": {
            "domain": [
              "Estimated nesting females",
              "Total clutches"
            ],
            "range": [
              [
                0
              ],
              [
                8,
                4
              ]
            ]
          },
          "legend": {
            "title": "Metric",
            "orient": "right",
            "symbolStrokeWidth": 2,
            "titleFontSize": 12,
            "labelFontSize": 11
          }
        },
        "strokeWidth": {
          "value": 2.5
        },
        "detail": [
          {
            "field": "species"
          },
          {
            "field": "metric_label"
          }
        ],
        "tooltip": [
          {
            "field": "year",
            "title": "Year"
          },
          {
            "field": "species",
            "title": "Species"
          },
          {
            "field": "metric_label",
            "title": "Metric"
          },
          {
            "field": "value",
            "title": "Count",
            "format": ","
