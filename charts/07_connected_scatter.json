      {
        "year": 2018,
        "landings": 12900,
        "hatchery_eggs": 1050000
      },
      {
        "year": 2019,
        "landings": 13400,
        "hatchery_eggs": 1120000
      },
      {
        "year": 2020,
        "landings": 13800,
        "hatchery_eggs": 1200000
      },
      {
        "year": 2021,
        "landings": 14100,
        "hatchery_eggs": 1280000
      },
      {
        "year": 2022,
        "landings": 14500,
        "hatchery_eggs": 1350000
      },
      {
        "year": 2023,
        "landings": 14800,
        "hatchery_eggs": 1420000
      }
    ]
  },
  "layer": [
    {
      "mark": {
        "type": "line",
        "color": "#aaa",
        "strokeWidth": 1.5,
        "opacity": 0.5
      },
      "encoding": {
        "x": {
          "field": "landings",
          "type": "quantitative",
          "axis": {
            "title": "Total female landings",
            "format": ","
          }
        },
        "y": {
          "field": "hatchery_eggs",
          "type": "quantitative",
          "axis": {
            "title": "Eggs secured in hatcheries",
            "format": "~s"
          }
        },
        "order": {
          "field": "year"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "size": 140,
        "filled": true,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "landings",
          "type": "quantitative"
        },
        "y": {
          "field": "hatchery_eggs",
          "type": "quantitative"
        },
        "color": {
          "field": "year",
          "type": "quantitative",
          "scale": {
            "scheme": "viridis"
          },
          "legend": {
            "title": "Year"
          }
        },
        "tooltip": [
          {
            "field": "year",
            "title": "Year"
          },
          {
            "field": "landings",
            "title": "Landings",
            "format": ","
          },
          {
            "field": "hatchery_eggs",
            "title": "Hatchery eggs",
            "format": ","
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2008 || datum.year == 2015 || datum.year == 2023"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "dx": 12,
        "dy": -6
      },
      "encoding": {
        "x": {
          "field": "landings",
          "type": "quantitative"
        },
        "y": {
          "field": "hatchery_eggs",
          "type": "quantitative"
        },
        "text": {
          "field": "year"
        },
        "color": {
          "value": "#333"
        }
      }
    }
  ]
}