{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Do more landings mean more protected eggs?",
    "subtitle": "Connected path traces Sabah's annual trajectory. Upward-right = improving. Source: Dept. of Fisheries",
    "fontSize": 16,
    "subtitleFontSize": 11,
    "anchor": "start",
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 360,
  "background": "#f7f9fb",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": true,
      "gridOpacity": 0.25
    }
  },
  "data": {
    "values": [
      {
        "year": 2008,
        "landings": 6800,
        "hatchery_eggs": 420000
      },
      {
        "year": 2009,
        "landings": 7200,
        "hatchery_eggs": 460000
      },
      {
        "year": 2010,
        "landings": 7800,
        "hatchery_eggs": 510000
      },
      {
        "year": 2011,
        "landings": 8400,
        "hatchery_eggs": 580000
      },
      {
        "year": 2012,
        "landings": 9100,
        "hatchery_eggs": 640000
      },
      {
        "year": 2013,
        "landings": 9800,
        "hatchery_eggs": 720000
      },
      {
        "year": 2014,
        "landings": 10500,
        "hatchery_eggs": 780000
      },
      {
        "year": 2015,
        "landings": 11200,
        "hatchery_eggs": 850000
