{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Warmer seas, fewer hawksbill nests at Chagar Hutang",
    "subtitle": "Path connects years 2000–2023 (3-year rolling means). Each point is one year",
    "fontSize": 18,
    "subtitleFontSize": 12,
    "anchor": "start",
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 360,
  "background": "#f7f9fb",
  "config": {"view": {"stroke": null}, "axis": {"grid": true, "gridOpacity": 0.3}},
  "data": {
    "values": [
      {"year": 2000, "sst_anomaly": 0.18, "nests": 320},
      {"year": 2001, "sst_anomaly": 0.22, "nests": 340},
      {"year": 2002, "sst_anomaly": 0.31, "nests": 310},
      {"year": 2003, "sst_anomaly": 0.27, "nests": 290},
      {"year": 2004, "sst_anomaly": 0.35, "nests": 280},
      {"year": 2005, "sst_anomaly": 0.42, "nests": 260},
      {"year": 2006, "sst_anomaly": 0.38, "nests": 245},
      {"year": 2007, "sst_anomaly": 0.45, "nests": 230},
      {"year": 2008, "sst_anomaly": 0.40, "nests": 220},
      {"year": 2009, "sst_anomaly": 0.52, "nests": 195},
      {"year": 2010, "sst_anomaly": 0.61, "nests": 175},
      {"year": 2011, "sst_anomaly": 0.48, "nests": 200},
      {"year": 2012, "sst_anomaly": 0.55, "nests": 185},
      {"year": 2013, "sst_anomaly": 0.62, "nests": 170},
      {"year": 2014, "sst_anomaly": 0.68, "nests": 155},
      {"year": 2015, "sst_anomaly": 0.82, "nests": 140},
      {"year": 2016, "sst_anomaly": 0.91, "nests": 125},
      {"year": 2017, "sst_anomaly": 0.74, "nests": 145},
      {"year": 2018, "sst_anomaly": 0.71, "nests": 155},
      {"year": 2019, "sst_anomaly": 0.85, "nests": 135},
      {"year": 2020, "sst_anomaly": 0.78, "nests": 150},
      {"year": 2021, "sst_anomaly": 0.83, "nests": 140},
      {"year": 2022, "sst_anomaly": 0.89, "nests": 130},
      {"year": 2023, "sst_anomaly": 0.95, "nests": 120}
    ]
  },
  "transform": [
    {
      "window": [
        {"op": "mean", "field": "sst_anomaly", "as": "sst_smooth"},
        {"op": "mean", "field": "nests", "as": "nests_smooth"}
      ],
      "frame": [-1, 1],
      "sort": [{"field": "year"}]
    }
  ],
  "layer": [
    {
      "mark": {"type": "line", "color": "#888", "strokeWidth": 1.5, "opacity": 0.5, "interpolate": "monotone"},
      "encoding": {
        "x": {"field": "sst_smooth", "type": "quantitative", "axis": {"title": "Sea surface temperature anomaly (°C above 1985–2000 baseline)"}, "scale": {"domain": [0.1, 1.0]}},
        "y": {"field": "nests_smooth", "type": "quantitative", "axis": {"title": "Hawksbill nests (3-year rolling mean)"}, "scale": {"domain": [100, 360]}},
        "order": {"field": "year"}
      }
    },
    {
      "mark": {"type": "circle", "size": 130, "opacity": 0.85, "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "x": {"field": "sst_smooth", "type": "quantitative"},
        "y": {"field": "nests_smooth", "type": "quantitative"},
        "color": {
          "field": "year",
          "type": "quantitative",
          "scale": {"scheme": "reds"},
          "legend": {"title": "Year", "orient": "bottom-right"}
        },
        "tooltip": [
          {"field": "year", "title": "Year"},
          {"field": "sst_anomaly", "title": "SST anomaly (°C)", "format": ".2f"},
          {"field": "nests", "title": "Nests (raw)"},
          {"field": "sst_smooth", "title": "SST (smoothed)", "format": ".2f"},
          {"field": "nests_smooth", "title": "Nests (smoothed)", "format": ".0f"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.year == 2000 || datum.year == 2010 || datum.year == 2016 || datum.year == 2023"}],
      "mark": {"type": "text", "fontSize": 10, "fontWeight": "bold", "color": "#333", "dx": 10, "dy": -4},
      "encoding": {
        "x": {"field": "sst_smooth", "type": "quantitative"},
        "y": {"field": "nests_smooth", "type": "quantitative"},
        "text": {"field": "year"}
      }
    }
  ]
}
