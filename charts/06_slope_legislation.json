{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Strict bans shift eggs from markets to hatcheries",
    "subtitle": "Percentage of eggs ending in commercial sale vs protected hatchery, by state. Source: Dept. of Fisheries",
    "fontSize": 16,
    "subtitleFontSize": 11,
    "anchor": "start",
    "subtitleColor": "#555"
  },
  "width": "container",
  "height": 340,
  "background": "#f7f9fb",
  "config": {"view": {"stroke": null}, "axis": {"grid": false}},
  "data": {
    "values": [
      {"state": "Sabah", "category": "Commercial market sales", "pct": 2},
      {"state": "Sabah", "category": "Protected hatchery incubation", "pct": 95},
      {"state": "Sarawak", "category": "Commercial market sales", "pct": 5},
      {"state": "Sarawak", "category": "Protected hatchery incubation", "pct": 88},
      {"state": "Terengganu", "category": "Commercial market sales", "pct": 38},
      {"state": "Terengganu", "category": "Protected hatchery incubation", "pct": 55},
      {"state": "Pahang", "category": "Commercial market sales", "pct": 42},
      {"state": "Pahang", "category": "Protected hatchery incubation", "pct": 48},
      {"state": "Perak", "category": "Commercial market sales", "pct": 65},
      {"state": "Perak", "category": "Protected hatchery incubation", "pct": 28},
      {"state": "Melaka", "category": "Commercial market sales", "pct": 52},
      {"state": "Melaka", "category": "Protected hatchery incubation", "pct": 40},
      {"state": "Johor", "category": "Commercial market sales", "pct": 58},
      {"state": "Johor", "category": "Protected hatchery incubation", "pct": 32},
      {"state": "Penang", "category": "Commercial market sales", "pct": 72},
      {"state": "Penang", "category": "Protected hatchery incubation", "pct": 18}
    ]
  },
  "layer": [
    {
      "mark": {"type": "line", "strokeWidth": 2, "opacity": 0.7},
      "encoding": {
        "x": {"field": "category", "type": "nominal", "sort": ["Commercial market sales", "Protected hatchery incubation"], "axis": {"title": null, "labelFontSize": 11, "labelFontWeight": "bold"}},
        "y": {"field": "pct", "type": "quantitative", "axis": {"title": "Percentage of total eggs"}},
        "color": {
          "field": "state",
          "type": "nominal",
          "scale": {
            "domain": ["Sabah", "Sarawak", "Terengganu", "Pahang", "Perak", "Melaka", "Johor", "Penang"],
            "range": ["#0077b6", "#2a9d8f", "#264653", "#f4a261", "#e9c46a", "#e76f51", "#9b2226", "#999"]
          },
          "legend": {"title": "State", "orient": "right"}
        },
        "detail": {"field": "state"},
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "category", "title": "Disposition"},
          {"field": "pct", "title": "Percentage", "format": ".0f"}
        ]
      }
    },
    {
      "mark": {"type": "circle", "size": 120, "filled": true, "stroke": "white", "strokeWidth": 1.5},
      "encoding": {
        "x": {"field": "category", "type": "nominal", "sort": ["Commercial market sales", "Protected hatchery incubation"]},
        "y": {"field": "pct", "type": "quantitative"},
        "color": {"field": "state", "type": "nominal"},
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "category", "title": "Disposition"},
          {"field": "pct", "title": "Percentage", "format": ".0f"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.category == 'Protected hatchery incubation'"}],
      "mark": {"type": "text", "align": "left", "dx": 8, "fontSize": 10},
      "encoding": {
        "x": {"field": "category", "type": "nominal", "sort": ["Commercial market sales", "Protected hatchery incubation"]},
        "y": {"field": "pct", "type": "quantitative"},
        "text": {"field": "state"},
        "color": {"field": "state", "type": "nominal", "legend": null}
      }
    }
  ]
}
