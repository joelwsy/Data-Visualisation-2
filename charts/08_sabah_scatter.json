  "params": [],
  "layer": [
    {
      "mark": {
        "type": "line",
        "color": "#b0bec5",
        "strokeWidth": 1.8
      },
      "encoding": {
        "x": {
          "field": "landings",
          "type": "quantitative",
          "axis": {
            "title": "Female turtle landings per year",
            "titleFontSize": 14,
            "format": ",d",
            "labelAngle": -30
          },
          "scale": {
            "domain": [
              6000,
              16000
            ]
          }
        },
        "y": {
          "field": "eggs_millions",
          "type": "quantitative",
          "axis": {
            "title": "Eggs secured in hatcheries (millions)",
            "titleFontSize": 14,
            "format": ".1f",
            "labelExpr": "datum.value + ' M'"
          },
          "scale": {
            "domain": [
              0.35,
              1.5
            ]
          }
        },
        "order": {
          "field": "year"
        }
      }
    },
    {
      "mark": {
        "type": "circle",
        "filled": true,
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "x": {
          "field": "landings",
          "type": "quantitative",
          "axis": {
            "title": "Female turtle landings per year",
            "titleFontSize": 14,
            "format": ",d",
            "labelAngle": -30
          },
          "scale": {
            "domain": [
              6000,
              16000
            ]
          }
        },
        "y": {
          "field": "eggs_millions",
          "type": "quantitative",
          "axis": {
            "title": "Eggs secured in hatcheries (millions)",
            "titleFontSize": 14,
            "format": ".1f",
            "labelExpr": "datum.value + ' M'"
          },
          "scale": {
            "domain": [
              0.35,
              1.5
            ]
          }
        },
        "size": {
          "value": 160
        },
        "color": {
          "field": "year",
          "type": "quantitative",
          "scale": {
            "scheme": "viridis"
          },
          "legend": {
            "title": "Year",
            "labelFontSize": 12,
            "titleFontSize": 13,
            "gradientLength": 120
          }
        },
        "tooltip": [
          {
            "field": "year",
            "title": "Year"
          },
          {
            "field": "landings",
            "title": "Female landings",
            "format": ","
          },
          {
            "field": "eggs_millions",
            "title": "Eggs in hatcheries (millions)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2008 || datum.year == 2014 || datum.year == 2019 || datum.year == 2023"
        }
      ],
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "bold",
        "color": "#1b3a4b",
        "dx": 10,
        "dy": -6
      },
      "encoding": {
        "x": {
          "field": "landings",
          "type": "quantitative",
          "axis": {
            "title": "Female turtle landings per year",
            "titleFontSize": 14,
            "format": ",d",
            "labelAngle": -30
          },
          "scale": {
            "domain": [
              6000,
              16000
            ]
          }
        },
        "y": {
          "field": "eggs_millions",
          "type": "quantitative",
          "axis": {
            "title": "Eggs secured in hatcheries (millions)",
            "titleFontSize": 14,
            "format": ".1f",
            "labelExpr": "datum.value + ' M'"
          },
          "scale": {
            "domain": [
              0.35,
              1.5
            ]
          }
        },
        "text": {
          "field": "year"
        }
      }
    }
  ],
  "transform": [
    {
      "calculate": "datum.hatchery_eggs / 1000000",
      "as": "eggs_millions"
    }
  ]
}