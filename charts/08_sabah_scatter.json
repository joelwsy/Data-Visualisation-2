{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Sabah: More Landings, More Eggs Saved",
    "subtitle": "Each point is one year (2008-2023). Path traces Sabah's annual conservation trajectory \u2014 upward-right = improving. Source: Sabah Parks, Dept. of Fisheries Malaysia",
    "fontSize": 22,
    "font": "Georgia",
    "subtitleFontSize": 14,
    "anchor": "start",
    "subtitleColor": "#666"
  },
  "width": "container",
  "height": 400,
  "background": "#f4f6f8",
  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "grid": true,
      "gridOpacity": 0.15,
      "labelFontSize": 13,
      "titleFontSize": 14
    }
  },
  "data": {
    "values": [
