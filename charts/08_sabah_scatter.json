        "hatchery_eggs": 1198000
      },
      {
        "year": 2021,
        "landings": 14100,
        "hatchery_eggs": 1275000
      },
      {
        "year": 2022,
        "landings": 14500,
        "hatchery_eggs": 1348000
      },
      {
        "year": 2023,
        "landings": 14800,
        "hatchery_eggs": 1420000
      }
